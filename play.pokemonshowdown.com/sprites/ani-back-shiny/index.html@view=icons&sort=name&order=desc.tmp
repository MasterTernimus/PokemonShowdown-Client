		.nav a, .nav a:visited {
			color: white;
			background: #3a4f88;
			background: linear-gradient(to bottom, #4c63a3, #273661);
			box-shadow: 0.5px 1px 2px rgba(255, 255, 255, 0.45), inset 0.5px 1px 1px rgba(255, 255, 255, 0.5);
